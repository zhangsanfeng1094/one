# Copy to .env (gitignored) or ~/.one/agent/.env — auto-loaded on CLI start
# (does not override variables already exported in the shell).
# Traces export via OpenTelemetry OTLP → {BASE}/api/public/otel/v1/traces
# US cloud: https://us.cloud.langfuse.com
# EU cloud: https://cloud.langfuse.com
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"
# Optional identity / env labels (propagated to every span)
# LANGFUSE_USER_ID=
# LANGFUSE_TRACING_ENVIRONMENT=dev
# LANGFUSE_RELEASE=0.1.0
# Enable tracing without passing --trace each time:
# ONE_TRACE=1
#
# Langfuse environment label (UI filter). Debug builds default to "dev"
# when unset; release builds stay unlabeled unless you set this.
# LANGFUSE_TRACING_ENVIRONMENT=dev
#
# Global install / run outside this repo: copy this file to
#   ~/.one/agent/.env
